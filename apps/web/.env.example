# Copy this to `.env.local` and fill in the values for the environment you're
# pointing at. Never commit `.env.local` (it holds secrets); only this example
# is tracked.
#
# dev/prod separation: this app talks to ONE Supabase project per env.
#   - Local Docker dev : URL http://127.0.0.1:54321  (keys from `supabase status`)
#   - Cloud DEV project: URL https://<dev-ref>.supabase.co
#   - Cloud PROD project: URL https://mnxcalicwnrcnxvcnfip.supabase.co
# Point .env.local at whichever you're developing against; set the PROD values
# in the deploy host (e.g. Vercel) — not here.

# --- Supabase (browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Google Maps JS API (browser-safe; Maps JS API enabled, billing on) ---
# Empty = the signup/location map falls back to manual lat/lng entry.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Biteship shipping aggregator — SERVER-ONLY (never prefix NEXT_PUBLIC_) ---
# Empty = shipping features are disabled gracefully.
BITESHIP_API_KEY=

# Where orders ship FROM by default (a HALINEST hub) — fallback when a
# manufacturer has no own origin set. Use lat/lng or a postal code.
SHIPPING_ORIGIN_LATITUDE=
SHIPPING_ORIGIN_LONGITUDE=
SHIPPING_ORIGIN_POSTAL_CODE=
# Comma-separated courier codes to quote (a default set is used if empty).
SHIPPING_COURIERS=
# Sender/hub contact for courier booking (Biteship create-order requires these).
SHIPPING_ORIGIN_CONTACT_NAME=
SHIPPING_ORIGIN_CONTACT_PHONE=
SHIPPING_ORIGIN_ADDRESS=
